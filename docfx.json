{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "group": "Sync",
          "src": "src/KubernetesCRDModelGen.Sync",
          "files": [
            "/bin/Release/net10.0/KubernetesCRDModelGen.Sync.dll"
          ]
        }
      ],
      "dest": "api/KubernetesCRDModelGen.Sync/"
    },
    {
      "src": [
        {
          "src": "src/Models/akuity.io",
          "files": [
            "/bin/Release/net10.0/KubernetesCRDModelGen.Models.akuity.io.dll"
          ]
        }
      ],
      "dest": "models/akuity.io"
    },
    {
      "src": [
        {
          "src": "src/Models/aquasecurity.github.io",
          "files": [
            "/bin/Release/net10.0/KubernetesCRDModelGen.Models.aquasecurity.github.io.dll"
          ]
        }
      ],
      "dest": "models/aquasecurity.github.io"
    },
    {
      "src": [
        {
          "src": "src/Models/k8s.aws",
          "files": [
            "/bin/Release/net10.0/KubernetesCRDModelGen.Models.k8s.aws.dll"
          ]
        }
      ],
      "dest": "models/k8s.aws"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "*.md",
          "*.yml",
          "api/**/*.{md,yml}",
          "docs/**/*.{md,yml}",
          "models/**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "KubernetesCRDModelGen.Models",
      "_appTitle": "KubernetesCRDModelGen.Models",
      "_enableSearch": false,
      "pdf": false
    }
  }
}