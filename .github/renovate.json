{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "timezone": "America/Vancouver",
  "dependencyDashboard": true,
  "semanticCommits": "enabled",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "assignees": [
    "@ivanjosipovic"
  ],
  "extends": [
    "config:recommended"
  ],
  "platformAutomerge": true,
  "ignorePaths": [
    "**/docs/**"
  ],
  "schedule": [
    "before 4am"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": false,
      "semanticCommitType": "fix",
      "matchFileNames": [
        "src/Models/**"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": true,
      "matchFileNames": [
        "global.json",
        "tests/**",
        "benchmarks/**"
      ]
    }
  ],
   "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^src\\/KubernetesCRDModelGen\\.Sync\\/ProjectGenerator\\.cs$/"
      ],
      "matchStrings": [
        "<PackageReference\\s+Include=\\\"(?<depName>[^\\\"]+)\\\"\\s+Version=\\\"(?<currentValue>[^\\\"]+)\\\"(?:\\s*/>|\\s*>)"
      ],
      "datasourceTemplate": "nuget",
      "versioningTemplate": "{{#if versioning}}{{{versioning}}}{{else}}semver{{/if}}"

    }
   ]
}